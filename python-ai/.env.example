MONGO_URI=mongodb://localhost:27017/cncpulse
MONGO_DB_NAME=cncpulse

MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_SENSOR_TOPIC=cncpulse/sensors
MQTT_GSM_CALL_TOPIC=cncpulse/gsm/call

DATASET_PATH=data/lstm_dataset.csv
OUTPUT_DATASET_PATH=data/lstm_dataset.csv
MODEL_PATH=models/maintenance_lstm.h5
PREPROCESSOR_PATH=models/lstm_preprocessor.json
TRAIN_METRICS_PATH=models/lstm_training_metrics.json
TRAINING_CURVE_PATH=models/lstm_training_curves.png
CONFUSION_MATRIX_PATH=models/lstm_confusion_matrix.png
RUNTIME_LOG_DIR=runtime/logs

SEQUENCE_LENGTH=30
WINDOW_STRIDE=1
TEST_RATIO=0.2
RANDOM_SEED=42
LSTM_EPOCHS=40
LSTM_BATCH_SIZE=64
LSTM_LEARNING_RATE=0.001
VALIDATION_SPLIT=0.2
EARLY_STOPPING_PATIENCE=8

SYNTHETIC_TARGET_RATIO=0.6
SYNTHETIC_MIN_PER_CLASS=300
SYNTHETIC_MAX_PER_CLASS=5000

ALERT_COOLDOWN_SEC=60
MODEL_RELOAD_SEC=15
MIN_HISTORY_FOR_ALERT=8

THRESHOLD_CURRENT_WARNING=15
THRESHOLD_CURRENT_CRITICAL=20
THRESHOLD_VIB_WARNING=2
THRESHOLD_VIB_CRITICAL=3
THRESHOLD_PRESSURE_WARNING_LOW=4.5
THRESHOLD_PRESSURE_WARNING_HIGH=10
THRESHOLD_PRESSURE_CRITICAL_LOW=3.5
THRESHOLD_PRESSURE_CRITICAL_HIGH=11

AUTO_TRAIN_INTERVAL_MINUTES=60
AUTO_TRAIN_RUN_ON_START=1
AUTO_TRAIN_STOP_ON_ERROR=0

UNSEEN_MINUTES=5
SUPERVISOR_POLL_SEC=15
GSM_MAX_ATTEMPTS=3

ENABLE_TTS=1
AUDIO_OUTPUT_DIR=runtime/audio
TTS_RATE=165
TTS_VOLUME=1.0
EMBED_AUDIO_BASE64=1
MAX_AUDIO_INLINE_BYTES=500000
